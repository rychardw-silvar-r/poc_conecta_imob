# ============================================================
# Conecta Imob - variáveis de ambiente
# Copie este arquivo para .env.local e preencha com seus valores
# ============================================================

# --- WhatsApp Cloud API (Meta for Developers) ---
# Como obter: developers.facebook.com -> Criar app -> WhatsApp -> API Setup
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
# Token arbitrário que VOCÊ define. Use o mesmo no painel do Meta ao configurar o webhook.
WHATSAPP_VERIFY_TOKEN=troque-por-uma-string-aleatoria-longa
# App Secret do app Meta (em Configurações -> Básico)
WHATSAPP_APP_SECRET=

# --- Supabase ---
# Como obter: supabase.com -> New Project -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Groq (transcrição com Whisper + extração com Llama 3.3 70B) ---
# Como obter: console.groq.com -> API Keys
GROQ_API_KEY=
